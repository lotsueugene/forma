# ===========================================
# Forma - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ----- Core -----
DATABASE_URL="postgresql://user:password@localhost:5432/forma"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""  # Generate with: openssl rand -base64 32

# ----- Server -----
SERVER_IP=""                          # VPS IP for custom domain verification
NEXT_PUBLIC_SERVER_IP=""              # Same IP, exposed to client
NEXT_PUBLIC_APP_DOMAIN="yourdomain.com"  # Your app's domain (used in middleware, SEO, etc.)

# ----- OAuth Providers (optional — enable one or both) -----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ----- Stripe (optional — for subscriptions and form payments) -----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_YEARLY_PRICE_ID=""

# ----- Email via Resend (optional — for automations, broadcasts, notifications) -----
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""
EMAIL_FROM="Forma <notifications@yourdomain.com>"

# ----- AWS S3 (optional — for file uploads) -----
AWS_S3_REGION="us-east-1"
AWS_S3_BUCKET="your-bucket-name"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ----- reCAPTCHA (optional — for signup spam protection) -----
RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""

# ----- Cron (for processing scheduled emails) -----
CRON_SECRET=""  # Generate with: openssl rand -hex 16
