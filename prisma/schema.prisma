// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("user") // user, admin
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  workspaceMembers   WorkspaceMember[]
  invitationsSent    Invitation[]
  settings           UserSettings?
  notifications      Notification[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Workspace (Organization) model
model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  isPersonal  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Stripe customer ID (for subscriptions)
  stripeCustomerId String?

  // Stripe Connect account ID (for receiving form payments)
  stripeConnectAccountId String?

  // Email notification settings
  notificationEmail String?  // Email to receive submission notifications

  // Branding
  logoUrl String?  // Logo URL for email broadcasts

  forms        Form[]
  members      WorkspaceMember[]
  invitations  Invitation[]
  integrations Integration[]
  apiKeys      ApiKey[]
  subscription Subscription?
  usageRecords UsageRecord[]
  notifications Notification[]
  webhookEndpoints WebhookEndpoint[]
  customDomain CustomDomain?
  respondentBroadcasts RespondentBroadcast[]
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  type        String   // submission, billing, system, etc.
  title       String
  body        String?
  href        String?

  readAt      DateTime?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([userId, readAt])
  @@index([userId, deletedAt])
}

// Subscription plans
// free: 50 submissions/month, 3 forms, no team, no analytics
// pro: unlimited submissions, unlimited forms, team, analytics ($29/month)
// trial: same as pro for 14 days
model Subscription {
  id                   String    @id @default(cuid())
  workspaceId          String?   @unique
  workspace            Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  plan                 String    @default("free") // free, pro, trial
  status               String    @default("active") // active, canceled, past_due, trialing

  // Stripe subscription data
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  stripeCurrentPeriodEnd DateTime?

  // Trial info
  trialEndsAt          DateTime?

  // Limits (can be overridden per workspace)
  submissionsLimit     Int       @default(50)
  formsLimit           Int       @default(3)
  membersLimit         Int       @default(1) // 1 = owner only (no team)

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

// Track monthly usage
model UsageRecord {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Period (monthly)
  periodStart DateTime
  periodEnd   DateTime

  // Counts
  submissions Int       @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, periodStart])
}

// Workspace membership with roles
model WorkspaceMember {
  id          String    @id @default(cuid())
  role        String    // owner, admin, editor, viewer

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, userId])
}

// Pending invitations
model Invitation {
  id          String    @id @default(cuid())
  email       String
  role        String    // admin, editor, viewer (not owner)
  token       String    @unique @default(cuid())
  expiresAt   DateTime

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  invitedById String
  invitedBy   User      @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())

  @@unique([workspaceId, email])
}

// Application models
model Form {
  id          String   @id @default(cuid())
  name        String
  description String?
  slug        String?  // URL-friendly slug for custom domains (e.g., "contact")
  status      String   @default("draft") // draft, active, archived, paused
  formType    String   @default("builder") // endpoint (quick) or builder (full)
  fields      String   @default("[]") // JSON string of form fields
  settings    String?  // JSON string of form settings

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  submissions Submission[]
  integrations Integration[]
  bookingBlocks BookingBlock[]
  respondentBroadcasts RespondentBroadcast[]
  defaultForDomains CustomDomain[] @relation("DefaultForm")

  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, slug])
}

model Submission {
  id        String   @id @default(cuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  data      String   // JSON string of submission data
  metadata  String?  // JSON string of metadata (IP, user agent, etc.)
  createdAt DateTime @default(now())
}

// Blocked times set by form owner (unavailable slots)
model BookingBlock {
  id        String   @id @default(cuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  fieldId   String   // Which booking field this applies to
  date      String   // "2026-04-15" for specific date, or empty for recurring
  startTime String?  // "12:00" — null means entire day blocked
  endTime   String?  // "13:00"
  reason    String?  // "Lunch break", "Day off"
  createdAt DateTime @default(now())

  @@index([formId, fieldId])
  @@index([formId, date])
}

model Integration {
  id          String   @id @default(cuid())
  type        String   // slack, zapier, hubspot, etc.
  name        String
  config      String   // JSON string of integration config (encrypted in production)
  enabled     Boolean  @default(true)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  formId      String?  // Optional: only trigger for this specific form (null = all forms)
  form        Form?    @relation(fields: [formId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// API Keys for workspace
model ApiKey {
  id          String    @id @default(cuid())
  name        String
  key         String    @unique  // The actual API key (hashed in production)
  prefix      String    // First 8 chars for display (e.g., "frm_live")
  lastUsedAt  DateTime?
  expiresAt   DateTime?

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// User notification preferences
model UserSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Notification preferences
  notifyNewSubmissions  Boolean  @default(true)
  notifyWeeklyDigest    Boolean  @default(true)
  notifyFormErrors      Boolean  @default(true)
  notifyTeamInvites     Boolean  @default(true)
  notifyBilling         Boolean  @default(true)
  notifyMarketing       Boolean  @default(false)

  // Other settings
  timezone              String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Outgoing webhook endpoints configured by workspace admins
model WebhookEndpoint {
  id             String    @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name           String
  url            String
  secret         String
  events         String    @default("submission.created") // comma-separated events
  active         Boolean   @default(true)

  lastTriggeredAt DateTime?
  lastStatusCode  Int?
  lastError       String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([workspaceId, active])
}

// One custom domain per workspace for now
model CustomDomain {
  id                String    @id @default(cuid())
  workspaceId       String    @unique
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  domain            String    @unique
  verificationToken String
  verifiedAt        DateTime?
  status            String    @default("pending") // pending, verified

  // Default form to show at root of custom domain
  defaultFormId     String?
  defaultForm       Form?     @relation("DefaultForm", fields: [defaultFormId], references: [id], onDelete: SetNull)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// Platform-wide announcements (admin only)
model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String    // Markdown or HTML
  type        String    @default("info") // info, warning, success, update
  priority    Int       @default(0) // Higher = more important

  // Targeting
  targetAll   Boolean   @default(true)
  targetPlans String?   // Comma-separated: "free,trial,pro" or null for all

  // Display settings
  dismissible Boolean   @default(true)
  showBanner  Boolean   @default(true) // Show as top banner
  showModal   Boolean   @default(false) // Show as modal on first visit

  // Scheduling
  startsAt    DateTime  @default(now())
  expiresAt   DateTime?

  // Tracking
  createdBy   String?   // Admin user ID

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([startsAt, expiresAt])
}

// Track which users have dismissed which announcements
model AnnouncementDismissal {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  dismissedAt    DateTime @default(now())

  @@unique([announcementId, userId])
  @@index([userId])
}

// Email broadcast tracking
model EmailBroadcast {
  id          String    @id @default(cuid())
  subject     String
  content     String    // HTML content

  // Targeting
  targetAll   Boolean   @default(true)
  targetPlans String?   // Comma-separated plans

  // Stats
  sentCount   Int       @default(0)
  failedCount Int       @default(0)

  // Status
  status      String    @default("draft") // draft, sending, sent, failed
  sentAt      DateTime?
  createdBy   String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  replies     BroadcastReply[]
}

// Workspace broadcasts to form respondents
model RespondentBroadcast {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  subject     String
  content     String    // HTML content
  fromName    String?   // Sender display name

  // Targeting
  formId      String?   // null = all forms
  form        Form?     @relation(fields: [formId], references: [id], onDelete: SetNull)

  // Stats
  recipientCount Int    @default(0)
  sentCount      Int    @default(0)
  failedCount    Int    @default(0)

  // Status
  status      String    @default("draft") // draft, sending, sent, failed
  sentAt      DateTime?
  createdBy   String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Replies to email broadcasts (via Resend inbound)
model BroadcastReply {
  id           String    @id @default(cuid())

  // Link to original broadcast (if identifiable)
  broadcastId  String?
  broadcast    EmailBroadcast? @relation(fields: [broadcastId], references: [id], onDelete: SetNull)

  // Sender info
  fromEmail    String
  fromName     String?

  // Email content
  subject      String
  textContent  String?   // Plain text body
  htmlContent  String?   // HTML body

  // Status
  status       String    @default("unread") // unread, read, replied
  readAt       DateTime?

  // Admin response
  repliedAt    DateTime?
  replyContent String?   // What admin replied with
  repliedBy    String?   // Admin user ID

  // Resend metadata
  resendEmailId String?  // Resend's email ID

  receivedAt   DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, receivedAt])
  @@index([fromEmail])
}

// Pricing plans (admin configurable)
model PricingPlan {
  id             String   @id @default(cuid())
  name           String   // e.g., "Starter", "Pro", "Enterprise"
  slug           String   @unique // e.g., "starter", "pro", "enterprise"
  description    String   // Short description

  // Pricing
  monthlyPrice   Float?   // Price in dollars (null for "Contact Sales")
  yearlyPrice    Float?   // Price in dollars per month when billed yearly

  // Limits (-1 = unlimited, used for enforcement)
  submissionsLimit Int     @default(50)   // Monthly submission limit
  formsLimit       Int     @default(3)    // Max forms allowed
  membersLimit     Int     @default(1)    // Max team members

  // Display
  icon           String   @default("Lightning") // Phosphor icon name
  popular        Boolean  @default(false)
  ctaText        String   @default("Get Started")
  ctaLink        String?  // Custom link (null = default signup)

  // Features (JSON array of {text: string, included: boolean})
  features       String   @default("[]")

  // Ordering and visibility
  sortOrder      Int      @default(0)
  active         Boolean  @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([active, sortOrder])
}

// Footer links (admin configurable)
model FooterLink {
  id          String   @id @default(cuid())
  section     String   // product, developers, company, legal
  label       String   // Display text
  href        String   // URL or path
  external    Boolean  @default(false) // Opens in new tab
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([section, active, sortOrder])
}

// Site settings (admin configurable key-value store)
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique // e.g., "footer_tagline", "system_status"
  value     String   // JSON value
  updatedAt DateTime @updatedAt
}

// Static pages (Privacy, Terms, About, Contact, etc.)
model Page {
  id          String    @id @default(cuid())
  slug        String    @unique // e.g., "privacy", "terms", "about"
  title       String
  content     String    // Markdown or HTML content
  metaTitle   String?   // SEO title
  metaDesc    String?   // SEO description
  published   Boolean   @default(false)
  publishedAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug, published])
}

// Blog posts
model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?   // Short summary
  content     String    // Markdown or HTML content
  coverImage  String?   // Cover image URL
  author      String?   // Author name
  tags        String?   // Comma-separated tags
  metaTitle   String?   // SEO title
  metaDesc    String?   // SEO description
  published   Boolean   @default(false)
  publishedAt DateTime?
  featured    Boolean   @default(false)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
  @@index([featured, published])
}

// Job postings for careers page
model JobPosting {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  department  String    // e.g., "Engineering", "Design", "Marketing"
  location    String    // e.g., "Remote", "San Francisco, CA"
  type        String    // e.g., "Full-time", "Part-time", "Contract"
  description String    // Full job description (Markdown)
  requirements String?  // Requirements/qualifications
  benefits    String?   // Benefits and perks
  salary      String?   // Salary range (optional)
  applyFormId String?   // Forma form ID for applications
  applyUrl    String?   // External application URL (fallback)
  applyEmail  String?   // Email to apply (fallback)
  published   Boolean   @default(false)
  publishedAt DateTime?
  featured    Boolean   @default(false)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
  @@index([department, published])
}

// Email unsubscribe tracking
model EmailUnsubscribe {
  id        String   @id @default(cuid())
  email     String
  scope     String   // "platform" (admin broadcasts) or workspaceId (workspace broadcasts)
  createdAt DateTime @default(now())

  @@unique([email, scope])
  @@index([email])
}
